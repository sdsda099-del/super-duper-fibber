name: Validate Prompt Files

on:
  push:
    paths:
      - '**.prompt.yml'
  pull_request:
    paths:
      - '**.prompt.yml'
  workflow_dispatch:

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install pyyaml

      - name: Validate all .prompt.yml files
        run: |
          import os
          import yaml
          import sys

          total_files = 0
          valid_files = 0
          error_files = 0

          print("🔍 Starting validation of .prompt.yml files...\n")

          for root, dirs, files in os.walk('.'):
              for file in files:
                  if file.endswith('.prompt.yml'):
                      total_files += 1
                      path = os.path.join(root, file)
                      print(f"\n📄 Checking: {path}")

                      try:
                          with open(path, 'r', encoding='utf-8') as f:
                              data = yaml.safe_load(f)

                          # Проверка: должен быть словарь
                          if not isinstance(data, dict):
                              print(f"   ❌ ERROR: Root is not a dictionary (found {type(data).__name__})")
                              error_files += 1
                              continue

                          # Проверка: наличие ключа 'messages'
                          if 'messages' not in data:
                              print(f"   ❌ ERROR: Missing required key 'messages'")
                              error_files += 1
                              continue

                          # Проверка: messages должен быть списком
                          if not isinstance(data['messages'], list):
                              print(f"   ❌ ERROR: 'messages' is not a list (found {type(data['messages']).__name__})")
                              error_files += 1
                              continue

                          # Проверка: каждый элемент списка должен быть словарём с 'role' и 'content'
                          for idx, msg in enumerate(data['messages']):
                              if not isinstance(msg, dict):
                                  print(f"   ❌ ERROR: messages[{idx}] is not a dictionary")
                                  error_files += 1
                                  break
                              if 'role' not in msg:
                                  print(f"   ❌ ERROR: messages[{idx}] missing 'role'")
                                  error_files += 1
                                  break
                              if 'content' not in msg:
                                  print(f"   ❌ ERROR: messages[{idx}] missing 'content'")
                                  error_files += 1
                                  break
                          else:
                              # Если все проверки пройдены
                              print(f"   ✅ VALID: Structure OK")
                              valid_files += 1

                      except yaml.YAMLError as e:
                          print(f"   ❌ YAML PARSE ERROR: {e}")
                          error_files += 1
                      except Exception as e:
                          print(f"   ❌ UNEXPECTED ERROR: {e}")
                          error_files += 1

          # Итоговый отчёт
          print("\n" + "="*50)
          print("📊 VALIDATION SUMMARY")
          print("="*50)
          print(f"Total files checked: {total_files}")
          print(f"✅ Valid: {valid_files}")
          print(f"❌ Errors: {error_files}")
          print("="*50)

          if error_files > 0:
              print("\n❌ Some files have errors. Please fix them.")
              sys.exit(1)
          else:
              print("\n✅ All files are valid!")
        shell: python
